{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Grep",
      "Read",
      "Edit",
      "Write",
      "Agent",
      "Bash"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -rf*)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "outputStyle": "default",
  "effortLevel": "xhigh",
  "voiceEnabled": true,
  "agentPushNotifEnabled": true
}
