[user]
	name = Aadit Shah
	email = aadit2805@gmail.com
	signingkey = ~/.ssh/id_ed25519_signing.pub
[core]
	excludesfile = ~/.gitignore_global
[init]
	defaultBranch = main
[column]
	ui = auto
[pull]
	rebase = false
[push]
	autoSetupRemote = true
[branch]
	sort = -committerdate
[gpg]
	program = /opt/homebrew/bin/gpg
	format = ssh
[commit]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
[credential]
	helper = store
